str(data)
# Summary statistics
summary(data)
# Check for missing values
sum(is.na(data))
# Distribution of outcome variable
table(data$aud_risk)
prop.table(table(data$aud_risk))
# Age distribution by risk level
ggplot(data, aes(x = age, fill = aud_risk)) +
geom_histogram(position = "dodge", bins = 30, alpha = 0.7) +
labs(title = "Age Distribution by AUD Risk Level",
x = "Age", y = "Count") +
theme_minimal()
# Risk by gender
ggplot(data, aes(x = gender, fill = aud_risk)) +
geom_bar(position = "fill") +
labs(title = "AUD Risk Proportion by Gender",
x = "Gender", y = "Proportion") +
theme_minimal()
# Family history impact
ggplot(data, aes(x = family_history, fill = aud_risk)) +
geom_bar(position = "fill") +
labs(title = "AUD Risk by Family History",
x = "Family History", y = "Proportion") +
theme_minimal()
